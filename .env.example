# Coolify / Docker environment variables example for GrowthNoteV3
# Copy this file to .env or configure these values directly in Coolify.

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:5056
ASPNETCORE_HTTP_PORTS=5056

# SQL Server connection string used by Program.cs via Configuration.GetConnectionString("Default")
# Replace the placeholder values with your actual database settings.
ConnectionStrings__Default=Server=your-db-host,1433;Database=your-database;User Id=your-user;Password=your-password;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=True;Connection Timeout=30
